# =============================================================================
# Supabase self-hosted (PRODUÇÃO) — template de .env
# =============================================================================
# Espelha as CHAVES do docker/.env real da VPS de prod (valores mascarados).
# O .env real vive SOMENTE na VPS + cofre de segredos — NUNCA neste repo.
# Itens marcados [SEGREDO] devem ser recuperados do cofre ou regenerados no DR.
# =============================================================================

# --- Postgres ---------------------------------------------------------------
POSTGRES_PASSWORD=__SEGREDO__
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# --- JWT / chaves de API ----------------------------------------------------
JWT_SECRET=__SEGREDO__
JWT_EXPIRY=3600
ANON_KEY=__SEGREDO__
SERVICE_ROLE_KEY=__SEGREDO__
SUPABASE_ANON_KEY=__SEGREDO__
SUPABASE_SERVICE_KEY=__SEGREDO__
SECRET_KEY_BASE=__SEGREDO__
VAULT_ENC_KEY=__SEGREDO__
PG_META_CRYPTO_KEY=__SEGREDO__

# --- Studio (dashboard) -----------------------------------------------------
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=__SEGREDO__
STUDIO_DEFAULT_ORGANIZATION=Cachola OS
STUDIO_DEFAULT_PROJECT=cacholaos
STUDIO_PORT=3000

# --- URLs públicas / API ----------------------------------------------------
SITE_URL=https://cachola.cloud
API_EXTERNAL_URL=https://api.cachola.cloud
SUPABASE_PUBLIC_URL=https://api.cachola.cloud
ADDITIONAL_REDIRECT_URLS=
GOTRUE_URI_ALLOW_LIST=

# --- Kong / Pooler (portas; bind 127.0.0.1 vem do patch) --------------------
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_TENANT_ID=
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=5

# --- Auth (GoTrue) ----------------------------------------------------------
GOTRUE_SITE_URL=https://cachola.cloud
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=false
GOTRUE_SMTP_ADMIN_EMAIL=
GOTRUE_SMTP_HOST=smtp.hostinger.com
GOTRUE_SMTP_PORT=465
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=__SEGREDO__
GOTRUE_SMTP_SENDER_NAME=Cachola OS
GOTRUE_MAILER_EXTERNAL_HOSTS=
DISABLE_SIGNUP=true
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# --- E-mail (templates/paths de convite — customização local) ---------------
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
MAILER_TEMPLATES_INVITE=
MAILER_SUBJECTS_INVITE=

# --- SMTP (compartilhado) ---------------------------------------------------
SMTP_ADMIN_EMAIL=
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=__SEGREDO__
SMTP_SENDER_NAME=Cachola OS

# --- Google OAuth (customização local) --------------------------------------
GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=__SEGREDO__
GOOGLE_SECRET=__SEGREDO__

# --- Storage / S3 -----------------------------------------------------------
STORAGE_BACKEND=file
GLOBAL_S3_BUCKET=stub
STORAGE_TENANT_ID=
REGION=

# --- Logflare / Analytics ---------------------------------------------------
LOGFLARE_LOGGER_BACKEND_API_KEY=__SEGREDO__
LOGFLARE_API_KEY=__SEGREDO__
LOGFLARE_PUBLIC_ACCESS_TOKEN=__SEGREDO__
LOGFLARE_PRIVATE_ACCESS_TOKEN=__SEGREDO__

# --- PostgREST --------------------------------------------------------------
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public,extensions

# --- Functions / imgproxy / docker ------------------------------------------
FUNCTIONS_VERIFY_JWT=false
IMGPROXY_AUTO_WEBP=true
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

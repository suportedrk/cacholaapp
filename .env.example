# ============================================================
# SUPABASE — Self-Hosted Local
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ============================================================
# NEXT.JS
# ============================================================
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_APP_NAME=Cachola OS

# ============================================================
# SUPABASE SELF-HOSTED — Config do Docker Compose
# (estas variáveis são usadas pelo docker-compose.yml)
# ============================================================
POSTGRES_PASSWORD=your-strong-postgres-password
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

JWT_SECRET=your-jwt-secret-at-least-32-chars
ANON_KEY=your-supabase-anon-key
SERVICE_ROLE_KEY=your-supabase-service-role-key

STUDIO_DEFAULT_ORGANIZATION=Cachola OS
STUDIO_DEFAULT_PROJECT=cacholaos

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@cacholaos.com.br
SMTP_SENDER_NAME=Cachola OS

# ============================================================
# E-MAIL — Resend (https://resend.com)
# ============================================================
# Obter API key em: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# Endereço de envio (deve ser verificado no Resend)
EMAIL_FROM=Cachola OS <no-reply@cacholaos.com.br>

# ============================================================
# ALERTAS AUTOMÁTICOS (cron)
# ============================================================
CRON_SECRET=your-cron-secret-here

# ============================================================
# PLOOMES CRM — Integração
# ============================================================
# Chave de usuário da API Ploomes (obter em Configurações → API no Ploomes)
# NUNCA commitar o valor real — usar apenas em .env local ou secrets de produção
PLOOMES_USER_KEY=your-ploomes-user-key-here
PLOOMES_API_URL=https://api2.ploomes.com/
PLOOMES_PIPELINE_ID=60000636
PLOOMES_STAGE_FESTA_FECHADA_ID=60004787
PLOOMES_WON_STATUS_ID=1
PLOOMES_SYNC_INTERVAL_MINUTES=15
# Secret para validar webhooks recebidos do Ploomes
PLOOMES_WEBHOOK_SECRET=your-ploomes-webhook-secret-here

# ============================================================
# PRODUÇÃO (preencher apenas no servidor)
# ============================================================
# SITE_URL=https://app.cacholaos.com.br
# API_EXTERNAL_URL=https://api.cacholaos.com.br

# ============================================================
# SEGURANÇA — NUNCA COMMITAR
# ============================================================
GITHUB_CREDENTIALS.MD
HOSTINGER_CREDENTIALS.MD
.env
.env.*
!.env.example

# ============================================================
# DEPENDÊNCIAS
# ============================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================================
# NEXT.JS
# ============================================================
/.next/
/out/
/build
next-env.d.ts

# ============================================================
# DOCKER / SUPABASE LOCAL
# ============================================================
/docker/volumes/
/supabase/.branches/
/supabase/.temp/

# ============================================================
# TESTES / COVERAGE
# ============================================================
/coverage
/.nyc_output

# ============================================================
# MISC
# ============================================================
.DS_Store
*.pem
Thumbs.db
*.tsbuildinfo

# ============================================================
# LOGS
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================
# VERCEL / CLOUD (não utilizado — self-hosted)
# ============================================================
.vercel

# ============================================================
# PWA — arquivos gerados pelo @ducanh2912/next-pwa (build artifacts)
# ============================================================
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/swe-worker-*.js
public/swe-worker-*.js.map

# ============================================================
# CLAUDE CODE — ignora tudo, mas mantém skills versionadas
# ============================================================
.claude/*
!.claude/skills/

# ============================================================
# SYNC LOCAL — dumps temporários (contêm dados reais anonimizados)
# ============================================================
tmp/
tmp/cachola-dump-*.sql.gz

# ============================================================
# SCRIPTS DE OPERAÇÕES PONTUAIS EM PRODUÇÃO
# Contêm credenciais/senhas em texto claro — NUNCA commitar.
# ============================================================
scripts/create-prod-test-users-*.sql
scripts/delete-prod-test-users-*.sql
.local-refs/

# ============================================================
# EDITORES
# ============================================================
.vscode/

# ============================================================
# SCRIPTS AD-HOC NA RAIZ
# Operações pontuais; podem conter credenciais — nunca versionar.
# Barra inicial = só na raiz, não afeta scripts/ ou supabase/.
# ============================================================
/*.py
/*.sh
/*.log
/*.out
/deploy_out.txt
/deploy_output.txt

# ============================================================
# DOCS COM CREDENCIAIS
# ============================================================
docs/SSH VPS.txt

# ============================================================
# IMAGENS DUPLICADAS (backups manuais de ícones)
# ============================================================
public/icons/*Copia*

# MCP config (local, não rastrear)
.mcp.json
